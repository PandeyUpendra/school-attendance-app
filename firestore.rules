rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Login / user registry ────────────────────────────────────────────────
    // App has no Firebase Auth — login is validated app-side against hashed
    // passwords stored here. Reads must be open so unauthenticated clients
    // can complete the Firestore-based login flow.
    match /allowed_users/{email} {
      allow read: if true;
      allow write: if false; // only Admin screen (PIN-gated) writes via app
    }

    // ── School-namespaced data (Gallery, Albums) ──────────────────────────────
    match /schools/{schoolId}/{document=**} {
      allow read, write: if true;
    }

    // ── Root-level app collections ────────────────────────────────────────────
    match /teachers/{doc=**}           { allow read, write: if true; }
    match /students/{doc=**}           { allow read, write: if true; }
    match /attendance/{doc=**}         { allow read, write: if true; }
    match /timetable/{doc=**}          { allow read, write: if true; }
    match /settings/{doc=**}           { allow read, write: if true; }
    match /duties/{doc=**}             { allow read, write: if true; }
    match /substitutions/{doc=**}      { allow read, write: if true; }
    match /leave_applications/{doc=**} { allow read, write: if true; }
    match /notifications/{doc=**}      { allow read, write: if true; }
    match /announcements/{doc=**}      { allow read, write: if true; }
    match /homework/{doc=**}           { allow read, write: if true; }
    match /exams/{doc=**}              { allow read, write: if true; }
    match /fees/{doc=**}               { allow read, write: if true; }
    match /copy_checks/{doc=**}        { allow read, write: if true; }
    match /staff_tasks/{doc=**}        { allow read, write: if true; }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
